---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="Page Not Found | 10 Billion Travelers">
  <section class="not-found">
    <div class="container">
      <h1>404</h1>
      <p>The page you're looking for doesn't exist.</p>
      <a href="/" class="btn">Back to Home</a>
    </div>
  </section>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding: 120px 0;
    background: var(--color-white);
  }
  .not-found h1 {
    font-size: 80px;
    color: var(--color-primary);
    margin-bottom: 16px;
  }
  .not-found p {
    font-size: 18px;
    margin-bottom: 32px;
  }
</style>
