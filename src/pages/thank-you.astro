---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
  title="Thank You | 10 Billion Travelers"
  description="Thank you for contacting 10 Billion Travelers."
>
  <section class="thankyou">
    <div class="container">
      <h1>Thank You!</h1>
      <p>for your submission</p>
      <p>We will contact you soon!</p>
      <a href="/" class="btn">Back to Home</a>
    </div>
  </section>
</Layout>

<style>
  .thankyou {
    text-align: center;
    padding: 120px 0;
    background: var(--color-white);
  }
  .thankyou h1 {
    color: var(--color-primary);
    margin-bottom: 16px;
  }
  .thankyou p {
    font-size: 18px;
    margin-bottom: 8px;
  }
  .thankyou .btn {
    margin-top: 32px;
  }
</style>
