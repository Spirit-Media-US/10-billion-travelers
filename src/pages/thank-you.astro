---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Thank You | 10 Billion Travelers"
  description="Thank you for contacting 10 Billion Travelers."
>
  <section class="thank-you">
    <div class="container thank-you-inner">
      <div class="check-icon">✓</div>
      <h1>Thank You!</h1>
      <p>We will contact you soon!!</p>
      <a href="/" class="btn thank-you-btn">Back to Home</a>
    </div>
  </section>
</Layout>

<style>
  .thank-you {
    padding: 120px 0;
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .check-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-white);
    font-size: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }
  .thank-you h1 {
    margin-bottom: 12px;
  }
  .thank-you p {
    font-size: 18px;
    color: var(--color-text-secondary);
  }
  .thank-you-inner {
    text-align: center;
  }
  .thank-you-btn {
    margin-top: 32px;
  }
</style>
