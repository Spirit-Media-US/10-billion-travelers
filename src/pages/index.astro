---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
	title="Travel Agencies in Raleigh | 10 Billion Travelers"
	description="Looking for the best travel agencies in Raleigh? Choose 10 Billion Travelers for expertly crafted tours and personalized travel experiences."
>
	<Fragment slot="head">
		<meta name="keywords" content="travel agencies in raleigh" />
	</Fragment>

	<!-- 1. Hero — full-width bg image with radial gradient overlay -->
	<section class="hero">
		<div class="hero-overlay"></div>
	</section>

	<!-- 2. Feature cards — 4 cards overlapping hero, black bottom border, rounded -->
	<section class="features">
		<div class="container">
			<div class="features-grid">
				<div class="feature-card">
					<img src="https://10btravelers.com/wp-content/uploads/2024/02/ezgif.com-optiwebp-6-150x150.webp" alt="Amazing Destinations" width="150" height="150" class="feature-icon" />
					<h2>Amazing Destinations</h2>
					<p>Amazing places around the globe to see</p>
				</div>
				<div class="feature-card">
					<img src="https://10btravelers.com/wp-content/uploads/2024/01/icon2-150x150.webp" alt="Great Accommodations" width="150" height="150" class="feature-icon" />
					<h2>Great Accommodations</h2>
					<p>Type of convenience and easily accessible</p>
				</div>
				<div class="feature-card">
					<img src="https://10btravelers.com/wp-content/uploads/2024/01/icon3-150x150.webp" alt="Super Fast Booking" width="150" height="150" class="feature-icon" />
					<h2>Super Fast Booking</h2>
					<p>Schedules, rates and reserve your ticket</p>
				</div>
				<div class="feature-card">
					<img src="https://10btravelers.com/wp-content/uploads/2024/01/icon2-150x150.webp" alt="Friendly Tour Guide" width="150" height="150" class="feature-icon" />
					<h2>Friendly Tour Guide</h2>
					<p>A perfect guide will be attentive and respectful</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 3. Photo gallery — large left, two stacked right -->
	<section class="gallery-1">
		<div class="container">
			<div class="gallery-1-grid">
				<div class="gallery-1-large">
					<img src="https://10btravelers.com/wp-content/uploads/2024/01/beach.webp" alt="Beach destination" width="1200" height="1200" loading="lazy" />
				</div>
				<div class="gallery-1-stack">
					<img src="https://10btravelers.com/wp-content/uploads/2024/01/beach3.webp" alt="Beach travel" width="1204" height="1204" loading="lazy" />
					<img src="https://10btravelers.com/wp-content/uploads/2024/01/beach2.webp" alt="Beach scenery" width="1200" height="1200" loading="lazy" />
				</div>
			</div>
		</div>
	</section>

	<!-- 4. Photo grid — 3 square images -->
	<section class="gallery-2">
		<div class="container">
			<div class="gallery-2-grid">
				<img src="https://10btravelers.com/wp-content/uploads/2024/01/pic1-1024x1024.webp" alt="Travel destination" width="1024" height="1024" loading="lazy" />
				<img src="https://10btravelers.com/wp-content/uploads/2024/01/pic2-1024x1024.webp" alt="Travel destination" width="1024" height="1024" loading="lazy" />
				<img src="https://10btravelers.com/wp-content/uploads/2024/01/pic3-1024x1024.webp" alt="Travel destination" width="1024" height="1024" loading="lazy" />
			</div>
		</div>
	</section>

	<!-- 5. CTA — "BEST TRAVEL" with bg image, badges -->
	<section class="best-travel">
		<div class="best-travel-overlay"></div>
		<div class="best-travel-inner container">
			<div class="best-travel-text">
				<p class="best-travel-label">LET'S JOIN AND PROVE IT</p>
				<h2 class="best-travel-heading">BEST TRAVEL</h2>
			</div>
			<div class="best-travel-badges">
				<div class="badge-item">
					<img src="https://10btravelers.com/wp-content/uploads/2023/10/630604fa0a1d0d335693c0d2-150x150.png" alt="Google Maps Local Guide" width="150" height="150" loading="lazy" />
					<div>
						<strong>Google Maps + Local Guide</strong>
						<p>Over 500,000 impacts!</p>
					</div>
				</div>
				<div class="badge-item">
					<img src="https://10btravelers.com/wp-content/uploads/2023/10/6306053e4548ae342af15010-150x150.png" alt="TripAdvisor Top 3 percent" width="150" height="150" loading="lazy" />
					<div>
						<strong>Top 3%</strong>
						<p>On Tripadvisor.com</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 6. Associations carousel -->
	<section class="associations">
		<div class="container">
			<h2>Associations</h2>
			<div class="associations-row">
				<img src="https://10btravelers.com/wp-content/uploads/2024/01/accredit.webp" alt="Accredited" width="405" height="153" loading="lazy" />
				<img src="https://10btravelers.com/wp-content/uploads/2024/01/world-foodtravel-association.webp" alt="World Food Travel Association" width="405" height="155" loading="lazy" />
				<img src="https://10btravelers.com/wp-content/uploads/2024/01/unwto.webp" alt="UNWTO" width="404" height="154" loading="lazy" />
			</div>
		</div>
	</section>

	<!-- 7. Bottom CTA — "TIME FOR ADVENTURE?" with island bg -->
	<section class="adventure-cta">
		<div class="adventure-cta-overlay"></div>
		<div class="adventure-cta-inner container">
			<div class="adventure-cta-content">
				<h2>Time for Adventure?</h2>
				<p>Contact us to learn about booking your trip</p>
			</div>
			<div class="adventure-cta-action">
				<a href="/about/" class="btn btn-primary">Get on My Mailing List</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* ===== 1. HERO ===== */
	.hero {
		position: relative;
		min-height: 633px;
		background: url("https://10btravelers.com/wp-content/uploads/2024/02/bg-homepage.webp") top center / cover no-repeat;
		background-color: #eeeeee;
	}
	.hero-overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(at center center, #000000 0%, #30C7B5 100%);
		opacity: 0.5;
	}
	@media (max-width: 767px) {
		.hero {
			min-height: 30vh;
			background-image: url("https://10btravelers.com/wp-content/uploads/2024/02/bg-mobile.jpeg");
			padding: 150px 20px 50px;
		}
	}
	@media (max-width: 1024px) and (min-width: 768px) {
		.hero {
			min-height: 40vh;
			padding: 100px 50px 50px;
		}
	}

	/* ===== 2. FEATURE CARDS ===== */
	.features {
		position: relative;
		z-index: 2;
		margin-top: -40px;
		padding-bottom: 40px;
	}
	.features-grid {
		display: flex;
		justify-content: space-evenly;
		gap: 0;
	}
	.feature-card {
		width: 23%;
		background: #ffffff;
		border-radius: 20px;
		border-bottom: 10px solid #000000;
		box-shadow: 0 4px 10px -1px rgba(0,0,0,0.5);
		padding: 20px;
		text-align: center;
		overflow: hidden;
	}
	.feature-icon {
		width: 50%;
		max-width: 50%;
		margin: 20px auto;
		border-radius: 50%;
	}
	.feature-card h2 {
		font-size: 19px;
		color: var(--color-primary);
		margin-bottom: 8px;
	}
	.feature-card p {
		font-size: 15px;
		color: var(--color-text);
		line-height: 1.5;
	}
	@media (max-width: 767px) {
		.features { margin-top: -40px; }
		.features-grid {
			flex-direction: column;
			align-items: center;
			gap: 60px;
		}
		.feature-card {
			width: 100%;
			max-width: 320px;
			margin-bottom: 0;
		}
	}
	@media (max-width: 1024px) and (min-width: 768px) {
		.features-grid { flex-wrap: wrap; justify-content: center; gap: 20px; }
		.feature-card { width: 45%; }
	}

	/* ===== 3. GALLERY 1 — large left + two stacked right ===== */
	.gallery-1 { padding: 24px 0; }
	.gallery-1-grid {
		display: flex;
		gap: 0;
	}
	.gallery-1-large {
		flex-shrink: 0;
		width: 57%;
	}
	.gallery-1-large img {
		width: 119%;
		border-radius: 10px;
		box-shadow: 4px 0 10px 0 rgba(0,0,0,0.5);
	}
	.gallery-1-stack {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0;
		padding: 0;
	}
	.gallery-1-stack img {
		width: 64%;
		margin-left: auto;
		border-radius: 10px;
		box-shadow: 4px 0 10px 0 rgba(0,0,0,0.5);
	}
	@media (max-width: 767px) {
		.gallery-1-grid { flex-direction: column; gap: 16px; }
		.gallery-1-large { width: 100%; }
		.gallery-1-large img { width: 100%; }
		.gallery-1-stack img { width: 100%; }
	}

	/* ===== 4. GALLERY 2 — 3 square images ===== */
	.gallery-2 { padding: 24px 0; }
	.gallery-2-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
	}
	.gallery-2-grid img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: 10px;
		box-shadow: 4px 0 10px 0 rgba(0,0,0,0.5);
	}
	@media (max-width: 767px) {
		.gallery-2-grid { grid-template-columns: 1fr; gap: 16px; }
	}

	/* ===== 5. BEST TRAVEL CTA ===== */
	.best-travel {
		position: relative;
		padding: 100px;
		background: url("https://10btravelers.com/wp-content/uploads/2024/02/bg-beach.jpg") center / cover no-repeat;
	}
	.best-travel-overlay {
		position: absolute;
		inset: 0;
		background: #000000;
		opacity: 0.63;
	}
	.best-travel-inner {
		position: relative;
		z-index: 1;
	}
	.best-travel-text {
		width: 100%;
		text-align: center;
		margin-bottom: 40px;
	}
	.best-travel-label {
		color: #ffffff;
		font-size: 16px;
		margin-bottom: 4px;
	}
	.best-travel-heading {
		color: var(--color-primary-hover);
		font-size: 70px;
		letter-spacing: 2px;
		line-height: 1;
		-webkit-text-stroke-color: #000;
	}
	.best-travel-badges {
		display: flex;
		gap: 0;
	}
	.badge-item {
		width: 50%;
		display: flex;
		align-items: center;
		gap: 15px;
	}
	.badge-item img {
		width: 30%;
		max-width: 80px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.badge-item strong {
		display: block;
		color: #ffffff;
		font-family: var(--font-heading);
		font-size: 16px;
		-webkit-text-stroke-color: #000;
	}
	.badge-item p {
		color: #ffffff;
		font-size: 14px;
		margin: 0;
	}
	@media (max-width: 767px) {
		.best-travel { padding: 40px 20px; }
		.best-travel-heading { font-size: 26px; letter-spacing: 1.8px; }
		.best-travel-label { font-size: 14px; }
		.best-travel-badges { flex-direction: column; gap: 24px; }
		.badge-item { width: 100%; }
	}

	/* ===== 6. ASSOCIATIONS ===== */
	.associations {
		padding: 40px 0;
		text-align: center;
	}
	.associations h2 {
		font-size: 56px;
		color: var(--color-primary-hover);
		text-transform: uppercase;
		margin-bottom: 32px;
		mix-blend-mode: darken;
	}
	.associations-row {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 40px;
		flex-wrap: wrap;
	}
	.associations-row img {
		max-width: 200px;
		height: auto;
	}
	@media (max-width: 767px) {
		.associations h2 { font-size: 32px; }
		.associations-row img { max-width: 150px; }
	}

	/* ===== 7. ADVENTURE CTA ===== */
	.adventure-cta {
		position: relative;
		border-radius: 15px;
		margin: 40px auto;
		max-width: var(--container-max);
		padding: 50px;
		background: url("https://10btravelers.com/wp-content/uploads/2024/02/island-bg.webp") bottom center / cover no-repeat;
		display: flex;
	}
	.adventure-cta-overlay {
		position: absolute;
		inset: 0;
		background: #000000;
		opacity: 0.49;
		border-radius: 15px;
	}
	.adventure-cta-inner {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: center;
		width: 100%;
		gap: 32px;
	}
	.adventure-cta-content {
		flex: 1;
	}
	.adventure-cta-content h2 {
		color: var(--color-primary-hover);
		font-size: 55px;
		text-transform: uppercase;
		line-height: 1.1;
	}
	.adventure-cta-content p {
		color: #ffffff;
		font-size: 20px;
		margin-top: 8px;
	}
	.adventure-cta-action {
		flex-shrink: 0;
	}
	.btn-primary {
		background: var(--color-primary);
		color: #ffffff;
		border-color: var(--color-primary);
		border-radius: 9px;
		padding: 16px 40px;
	}
	.btn-primary:hover {
		background: var(--color-primary-hover);
		border-color: var(--color-primary-hover);
		color: #ffffff;
	}
	@media (max-width: 767px) {
		.adventure-cta { padding: 30px 20px; margin: 20px 16px; }
		.adventure-cta-inner { flex-direction: column; text-align: center; }
		.adventure-cta-content h2 { font-size: 28px; }
		.adventure-cta-content p { font-size: 16px; }
	}
</style>
