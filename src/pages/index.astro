---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
	title="Travel Agencies in Raleigh | 10 Billion Travelers"
	description="Looking for the best travel agencies in Raleigh? Choose 10 Billion Travelers for expertly crafted tours and personalized travel experiences."
>
	<Fragment slot="head">
		<meta name="keywords" content="travel agencies in raleigh" />
	</Fragment>

	<!-- Hero: logo + heading + subtitle (matches original Elementor hero) -->
	<section class="hero">
		<div class="hero-overlay"></div>
		<div class="hero-content container">
			<img
				src="https://10btravelers.com/wp-content/uploads/2024/02/ezgif.com-optiwebp-6-150x150.webp"
				alt="10 Billion Travelers logo"
				width="150"
				height="150"
				class="hero-logo"
			/>
			<h1>Amazing<br />Destinations</h1>
			<p class="hero-sub">Amazing places around the globe to see</p>
		</div>
	</section>

	<!-- Features: 4 columns with icon images -->
	<section class="features">
		<div class="container">
			<div class="features-grid">
				<div class="feature-card">
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/icon2-150x150.webp"
						alt="Amazing Destinations icon"
						width="150"
						height="150"
						class="feature-icon"
					/>
					<h3>Amazing Destinations</h3>
					<p>Amazing places around the globe to see</p>
				</div>
				<div class="feature-card">
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/icon2-150x150.webp"
						alt="Great Accommodations icon"
						width="150"
						height="150"
						class="feature-icon"
					/>
					<h3>Great Accommodations</h3>
					<p>Type of convenience and easily accessible</p>
				</div>
				<div class="feature-card">
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/icon3-150x150.webp"
						alt="Super Fast Booking icon"
						width="150"
						height="150"
						class="feature-icon"
					/>
					<h3>Super Fast Booking</h3>
					<p>Schedules, rates and reserve your ticket</p>
				</div>
				<div class="feature-card">
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/icon2-150x150.webp"
						alt="Friendly Tour Guide icon"
						width="150"
						height="150"
						class="feature-icon"
					/>
					<h3>Friendly Tour Guide</h3>
					<p>A perfect guide will be attentive and respectful</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Gallery 1: large image left, two stacked right (matches original layout) -->
	<section class="gallery-section">
		<div class="container">
			<div class="gallery-layout-1">
				<div class="gallery-large">
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/beach.webp"
						alt="Beach destination"
						width="1200"
						height="1200"
						loading="lazy"
					/>
				</div>
				<div class="gallery-stack">
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/beach3.webp"
						alt="Beach travel photo"
						width="1204"
						height="1204"
						loading="lazy"
					/>
					<img
						src="https://10btravelers.com/wp-content/uploads/2024/01/beach2.webp"
						alt="Beach destination photo"
						width="1200"
						height="1200"
						loading="lazy"
					/>
				</div>
			</div>
		</div>
	</section>

	<!-- Gallery 2: 3 square images (pic1, pic2, pic3) -->
	<section class="gallery-section">
		<div class="container">
			<div class="gallery-grid-3">
				<img
					src="https://10btravelers.com/wp-content/uploads/2024/01/pic1-1024x1024.webp"
					alt="Travel destination"
					width="1024"
					height="1024"
					loading="lazy"
				/>
				<img
					src="https://10btravelers.com/wp-content/uploads/2024/01/pic2-1024x1024.webp"
					alt="Travel destination"
					width="1024"
					height="1024"
					loading="lazy"
				/>
				<img
					src="https://10btravelers.com/wp-content/uploads/2024/01/pic3-1024x1024.webp"
					alt="Travel destination"
					width="1024"
					height="1024"
					loading="lazy"
				/>
			</div>
		</div>
	</section>

	<!-- CTA with badges -->
	<section class="cta-section">
		<div class="container">
			<div class="cta-grid">
				<div class="cta-text">
					<p class="cta-label">Let's Join and Prove It</p>
					<h2>Best Travel</h2>
				</div>
				<div class="cta-badges">
					<div class="badge">
						<img
							src="https://10btravelers.com/wp-content/uploads/2023/10/630604fa0a1d0d335693c0d2-150x150.png"
							alt="Google Maps + Local Guide"
							width="60"
							height="60"
							loading="lazy"
						/>
						<div>
							<strong>Google Maps + Local Guide</strong>
							<p>Over 500,000 impacts!</p>
						</div>
					</div>
					<div class="badge">
						<img
							src="https://10btravelers.com/wp-content/uploads/2023/10/6306053e4548ae342af15010-150x150.png"
							alt="TripAdvisor Top 3%"
							width="60"
							height="60"
							loading="lazy"
						/>
						<div>
							<strong>Top 3%</strong>
							<p>On Tripadvisor.com</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hero — background image with logo + text overlay */
	.hero {
		position: relative;
		min-height: 550px;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		background: url("https://10btravelers.com/wp-content/uploads/2024/01/beach.webp") center/cover no-repeat;
		background-color: #eeeeee;
	}
	.hero-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.4);
	}
	.hero-content {
		position: relative;
		z-index: 1;
		padding: 60px 24px;
	}
	.hero-logo {
		width: 150px;
		height: 150px;
		margin: 0 auto 24px;
		border-radius: 50%;
		border: 3px solid rgba(255,255,255,0.3);
	}
	.hero h1 {
		text-transform: uppercase;
		letter-spacing: 3px;
		font-size: 42px;
		color: #ffffff;
		text-shadow: 0 2px 8px rgba(0,0,0,0.4);
	}
	.hero-sub {
		color: rgba(255,255,255,0.9);
		font-size: 18px;
		margin-top: 12px;
		text-shadow: 0 1px 4px rgba(0,0,0,0.3);
	}

	/* Features — 4 columns with circular icon images */
	.features {
		padding: 60px 0;
		background: var(--color-white);
	}
	.features-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 24px;
		text-align: center;
	}
	.feature-card {
		padding: 24px 16px;
	}
	.feature-icon {
		width: 80px;
		height: 80px;
		margin: 0 auto 20px;
		border-radius: 50%;
		object-fit: cover;
	}
	.feature-card h3 {
		font-size: 16px;
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: 12px;
		color: var(--color-heading);
	}
	.feature-card p {
		font-size: 15px;
		color: var(--color-text);
		line-height: 1.6;
	}

	/* Gallery layout 1: large left, two stacked right */
	.gallery-section {
		padding: 24px 0;
	}
	.gallery-layout-1 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}
	.gallery-large img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.gallery-stack {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.gallery-stack img {
		width: 100%;
		flex: 1;
		object-fit: cover;
	}

	/* Gallery grid: 3 equal squares */
	.gallery-grid-3 {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}
	.gallery-grid-3 img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
	}

	/* CTA with badges */
	.cta-section {
		padding: 60px 0;
		background: var(--color-bg);
	}
	.cta-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 48px;
		align-items: center;
	}
	.cta-label {
		font-family: var(--font-heading);
		font-size: 14px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: var(--color-text-secondary);
		margin-bottom: 8px;
	}
	.cta-section h2 {
		font-size: 36px;
		text-transform: uppercase;
		letter-spacing: 2px;
		color: var(--color-primary);
	}
	.cta-badges {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}
	.badge {
		display: flex;
		align-items: center;
		gap: 16px;
	}
	.badge img {
		width: 60px;
		height: 60px;
		border-radius: 50%;
		flex-shrink: 0;
	}
	.badge strong {
		display: block;
		font-family: var(--font-heading);
		font-size: 16px;
		color: var(--color-heading);
	}
	.badge p {
		font-size: 14px;
		color: var(--color-text-secondary);
		margin: 0;
	}

	@media (max-width: 768px) {
		.hero { min-height: 350px; }
		.hero h1 { font-size: 28px; }
		.features-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
		.gallery-layout-1 { grid-template-columns: 1fr; }
		.gallery-grid-3 { grid-template-columns: 1fr; }
		.cta-grid { grid-template-columns: 1fr; gap: 32px; }
	}
	@media (max-width: 480px) {
		.features-grid { grid-template-columns: 1fr; }
	}
</style>
