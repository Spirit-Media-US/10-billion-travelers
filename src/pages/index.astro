---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { sanityClient, urlFor } from "../lib/sanity";

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const features = await sanityClient.fetch(
	`*[_type == "feature"] | order(order asc)`,
);
const travelPhotos = await sanityClient.fetch(
	`*[_type == "galleryImage" && section == "travel"] | order(order asc)`,
);
const bestPhotos = await sanityClient.fetch(
	`*[_type == "galleryImage" && section == "best"] | order(order asc) [0...3]`,
);

const heroBase = settings?.heroImage
	? urlFor(settings.heroImage).url().split("?")[0]
	: "https://cdn.sanity.io/images/2voldnur/production/6e299e952d906041d8de47e436283d1125e54c43-2369x940.webp";
const heroMobileBase =
	"https://cdn.sanity.io/images/2voldnur/production/a40a8123ab7929f7f5bd4b642dada747e1f6eee1-895x940.jpg";
const heroMobile = `${heroMobileBase}?w=480&fm=webp&q=60`;
const heroMobile2x = `${heroMobileBase}?w=760&fm=webp&q=55`;
const heroDesktop = `${heroBase}?w=1600&fm=webp&q=70`;
---

<Layout
	title="Travel Agencies in Raleigh | 10 Billion Travelers"
	description="Looking for the best travel agencies in Raleigh? Choose 10 Billion Travelers for expertly crafted tours and personalized travel experiences."
>
	<Fragment slot="head">
		<!-- Desktop-only hero preload. Mobile never fetches the hero image —
		     mobile LCP is the H1 text node (paints from the HTML stream). -->
		<link
			rel="preload"
			as="image"
			href={heroDesktop}
			fetchpriority="high"
			media="(min-width: 768px)"
		/>
	</Fragment>

	<!-- MOBILE HERO — text-first, H1 is LCP. CSS-gated via .hero-mobile
	     media query; desktop hides this block. -->
	<section class="hero-mobile">
		<div class="hero-mobile-inner">
			<p class="hero-eyebrow">Travel Agencies in Raleigh</p>
			<h1 class="hero-heading">Expertly Crafted Tours, Personalized Experiences</h1>
			<p class="hero-sub">Over 1 million miles logged. 26 countries explored. Let's plan your next adventure.</p>
			<a href="/about/" class="btn btn-primary hero-cta">Meet Kevin</a>
		</div>
	</section>

	<!-- DESKTOP HERO — full-viewport photo with radial overlay. Hidden below
	     768px so mobile never pays the image download cost. The <img>
	     fallback is a 1×1 GIF data URI — no HTTP request on mobile even
	     though the tag is still parsed. -->
	<section class="hero hero-desktop">
		<picture>
			<source
				media="(min-width: 768px)"
				srcset={heroDesktop}
			/>
			<img
				src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=="
				alt=""
				aria-hidden="true"
				width="1600"
				height="634"
				fetchpriority="high"
				loading="eager"
				decoding="async"
				class="hero-img"
			/>
		</picture>
		<div class="hero-overlay"></div>
	</section>

	<!-- 2. Feature cards — 4 cards overlapping hero, black bottom border, rounded -->
	<section class="features">
		<div class="container">
			<div class="features-grid">
				{features.map((f: any) => (
					<div class="feature-card">
						{f.icon && <img src={urlFor(f.icon).width(160).height(160).format('webp').quality(75).url()} alt={f.title} width="80" height="80" class="feature-icon" loading="lazy" decoding="async" />}
						<h2>{f.title}</h2>
						<p>{f.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- 3. Gallery — large left, two stacked right -->
	<section class="gallery-row">
		<div class="container">
			<div class="gallery-asymmetric">
				{travelPhotos[0] && (
					<div class="gallery-big">
						<img
							src={urlFor(travelPhotos[0].image).width(1200).format('webp').quality(70).url()}
							srcset={`${urlFor(travelPhotos[0].image).width(420).format('webp').quality(62).url()} 420w, ${urlFor(travelPhotos[0].image).width(720).format('webp').quality(65).url()} 720w, ${urlFor(travelPhotos[0].image).width(1200).format('webp').quality(70).url()} 1200w`}
							sizes="(max-width: 767px) 88vw, 55vw"
							alt={travelPhotos[0].image?.alt || travelPhotos[0].title}
							width="1200"
							height="900"
							loading="lazy"
							decoding="async"
						/>
					</div>
				)}
				{travelPhotos[1] && (
					<div class="gallery-right-img">
						<img
							src={urlFor(travelPhotos[1].image).width(600).format('webp').quality(68).url()}
							srcset={`${urlFor(travelPhotos[1].image).width(420).format('webp').quality(62).url()} 420w, ${urlFor(travelPhotos[1].image).width(600).format('webp').quality(68).url()} 600w`}
							sizes="(max-width: 767px) 88vw, 30vw"
							alt={travelPhotos[1].image?.alt || travelPhotos[1].title}
							width="600"
							height="450"
							loading="lazy"
							decoding="async"
						/>
					</div>
				)}
				{travelPhotos[2] && (
					<div class="gallery-right-img">
						<img
							src={urlFor(travelPhotos[2].image).width(600).format('webp').quality(68).url()}
							srcset={`${urlFor(travelPhotos[2].image).width(420).format('webp').quality(62).url()} 420w, ${urlFor(travelPhotos[2].image).width(600).format('webp').quality(68).url()} 600w`}
							sizes="(max-width: 767px) 88vw, 30vw"
							alt={travelPhotos[2].image?.alt || travelPhotos[2].title}
							width="600"
							height="450"
							loading="lazy"
							decoding="async"
						/>
					</div>
				)}
			</div>
		</div>
	</section>

	<!-- 4. Gallery — 3 equal columns from Sanity -->
	<section class="gallery-row">
		<div class="container">
			<div class="gallery-three">
				{bestPhotos.map((p: any) => (
					<div class="gallery-three-col">
						<img
							src={urlFor(p.image).width(720).height(720).format('webp').quality(65).url()}
							srcset={`${urlFor(p.image).width(400).height(400).format('webp').quality(62).url()} 400w, ${urlFor(p.image).width(720).height(720).format('webp').quality(65).url()} 720w`}
							sizes="(max-width: 767px) 88vw, 30vw"
							alt={p.image?.alt || p.title}
							width="720"
							height="720"
							loading="lazy"
							decoding="async"
						/>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- 5. CTA — "BEST TRAVEL" with bg image, badges -->
	<section class="best-travel">
		<div class="best-travel-overlay"></div>
		<div class="best-travel-inner container">
			<div class="best-travel-text">
				<p class="best-travel-label">THE CREDENTIALS</p>
				<h2 class="best-travel-heading">TRUSTED WORLDWIDE</h2>
			</div>
			<div class="best-travel-badges">
				<div class="badge-item">
					<img src="https://cdn.sanity.io/images/2voldnur/production/0589b9373e45bc50e08959863a7a691cd0564b97-150x150.png?w=160&h=160&fm=webp&q=60" alt="Google Maps Local Guide" width="80" height="80" loading="lazy" decoding="async" />
					<div>
						<strong>Google Maps + Local Guide</strong>
						<p>Over 500,000 impacts!</p>
					</div>
				</div>
				<div class="badge-item">
					<img src="https://cdn.sanity.io/images/2voldnur/production/1d20a81206c101dcc09a0dcd832827bdca062e99-150x150.png?w=160&h=160&fm=webp&q=60" alt="TripAdvisor Top 3 percent" width="80" height="80" loading="lazy" decoding="async" />
					<div>
						<strong>Top 3%</strong>
						<p>On Tripadvisor.com</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- 6. Associations — looping slider (desktop), 1-per-slide (mobile) -->
	<section class="associations">
		<div class="container">
			<h2>Associations</h2>
			<div class="assoc-slider" id="assoc-slider">
				<button class="assoc-arrow assoc-prev" id="assoc-prev" aria-label="Previous">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
				</button>
				<div class="assoc-viewport">
					<div class="assoc-track" id="assoc-track">
						<div class="assoc-slide"><img src="https://cdn.sanity.io/images/2voldnur/production/fd785de645c67d8b8d0651a953b302e4f0f47798-405x153.webp?w=405&fm=webp&q=80" alt="Accredited Media" width="405" height="153" loading="lazy" decoding="async" /></div>
						<div class="assoc-slide"><img src="https://cdn.sanity.io/images/2voldnur/production/86f546c6c54b113a83f32589f1c9ced0aab416a3-405x155.webp?w=405&fm=webp&q=80" alt="World Food Travel Association" width="405" height="155" loading="lazy" decoding="async" /></div>
						<div class="assoc-slide"><img src="https://cdn.sanity.io/images/2voldnur/production/abef94d0c81c8c93d4c113587f697f6a4a8bfb03-404x154.webp?w=404&fm=webp&q=80" alt="UNWTO" width="404" height="154" loading="lazy" decoding="async" /></div>
						<!-- Clones for desktop infinite loop -->
						<div class="assoc-slide assoc-clone"><img src="https://cdn.sanity.io/images/2voldnur/production/fd785de645c67d8b8d0651a953b302e4f0f47798-405x153.webp?w=405&fm=webp&q=80" alt="Accredited Media" width="405" height="153" loading="lazy" decoding="async" aria-hidden="true" /></div>
						<div class="assoc-slide assoc-clone"><img src="https://cdn.sanity.io/images/2voldnur/production/86f546c6c54b113a83f32589f1c9ced0aab416a3-405x155.webp?w=405&fm=webp&q=80" alt="World Food Travel Association" width="405" height="155" loading="lazy" decoding="async" aria-hidden="true" /></div>
						<div class="assoc-slide assoc-clone"><img src="https://cdn.sanity.io/images/2voldnur/production/abef94d0c81c8c93d4c113587f697f6a4a8bfb03-404x154.webp?w=404&fm=webp&q=80" alt="UNWTO" width="404" height="154" loading="lazy" decoding="async" aria-hidden="true" /></div>
					</div>
				</div>
				<button class="assoc-arrow assoc-next" id="assoc-next" aria-label="Next">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
				</button>
			</div>
			<div class="assoc-dots">
				<button class="assoc-dot active" data-index="0" aria-label="Slide 1"></button>
				<button class="assoc-dot" data-index="1" aria-label="Slide 2"></button>
				<button class="assoc-dot" data-index="2" aria-label="Slide 3"></button>
			</div>
		</div>
	</section>

	<script>
	(function() {
		var track = document.getElementById('assoc-track');
		var dots = document.querySelectorAll('.assoc-dot');
		var prev = document.getElementById('assoc-prev');
		var next = document.getElementById('assoc-next');
		if (!track) return;

		var pos = 0;

		function isMobile() { return window.innerWidth <= 767; }

		function slideTo(p) {
			pos = p;
			if (isMobile()) {
				// Mobile: 3 real slides only (clones hidden), each 100% width, track = 300%
				pos = ((p % 3) + 3) % 3;
				track.style.transition = 'transform 0.5s ease';
				track.style.transform = 'translateX(-' + (pos * (100 / 3)) + '%)';
			} else {
				// Desktop: 6 slides (3 + 3 clones) at 33.333% each, showing 3 at a time
				var slideWidth = 100 / 6;
				track.style.transition = 'transform 0.5s ease';
				track.style.transform = 'translateX(-' + (pos * slideWidth) + '%)';
			}
			dots.forEach(function(d, i) { d.classList.toggle('active', i === (pos % 3)); });
		}

		track.addEventListener('transitionend', function() {
			if (!isMobile() && pos >= 3) {
				track.style.transition = 'none';
				pos = 0;
				track.style.transform = 'translateX(0%)';
			}
		});

		prev.addEventListener('click', function() {
			if (!isMobile() && pos <= 0) {
				track.style.transition = 'none';
				pos = 3;
				track.style.transform = 'translateX(-' + (pos * (100 / 6)) + '%)';
				requestAnimationFrame(function() {
					requestAnimationFrame(function() { slideTo(pos - 1); });
				});
			} else {
				slideTo(pos - 1);
			}
		});
		next.addEventListener('click', function() { slideTo(pos + 1); });
		dots.forEach(function(d) {
			d.addEventListener('click', function() { slideTo(Number(d.dataset.index)); });
		});

		var interval = setInterval(function() { slideTo(pos + 1); }, 5000);
		document.getElementById('assoc-slider').addEventListener('mouseenter', function() { clearInterval(interval); });
		document.getElementById('assoc-slider').addEventListener('mouseleave', function() {
			interval = setInterval(function() { slideTo(pos + 1); }, 5000);
		});
	})();
	</script>

	<!-- 7. Bottom CTA — "TIME FOR ADVENTURE?" with island bg -->
	<section class="adventure-cta">
		<div class="adventure-cta-overlay"></div>
		<div class="adventure-cta-inner container">
			<div class="adventure-cta-content">
				<h2>TIME FOR ADVENTURE?</h2>
				<p>CONTACT US TO LEARN ABOUT BOOKING YOUR TRIP</p>
			</div>
			<div class="adventure-cta-action">
				<a href="/about/" class="btn btn-primary">GET ON MY MAILING LIST</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* ===== 1. HERO ===== */
	/* Mobile text-first hero — H1 is LCP. Rendered only below 768px. */
	.hero-mobile {
		display: none;
		background: linear-gradient(180deg, #ffffff 0%, var(--color-bg) 100%);
		padding: 40px 24px 48px;
	}
	.hero-mobile-inner {
		max-width: 560px;
		margin: 0 auto;
		text-align: center;
	}
	.hero-eyebrow {
		font-family: var(--font-heading);
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: var(--color-primary-dark);
		margin: 0 0 12px;
	}
	.hero-heading {
		font-family: var(--font-heading);
		font-size: 30px;
		font-weight: 700;
		line-height: 1.15;
		color: var(--color-heading);
		margin: 0 0 16px;
		text-wrap: balance;
	}
	.hero-sub {
		font-size: 16px;
		color: var(--color-text);
		line-height: 1.55;
		margin: 0 0 24px;
	}
	.hero-cta {
		border-radius: 9px;
	}
	@media (max-width: 767px) {
		.hero-mobile { display: block; }
	}

	/* Skip paint + layout for offscreen sections on mobile.
	   Cuts ~200-400ms of synchronous layout work during initial render
	   on throttled CPU, which advances LCP of the H1 above. */
	@media (max-width: 767px) {
		.features,
		.gallery-row,
		.best-travel,
		.associations,
		.adventure-cta {
			content-visibility: auto;
			contain-intrinsic-size: 1px 600px;
		}
	}

	/* Desktop photo hero — hidden below 768px via .hero-desktop media query below. */
	.hero {
		position: relative;
		min-height: 633px;
		background-color: #eeeeee;
		overflow: hidden;
	}
	.hero-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
		display: block;
	}
	.hero-overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(at center center, #000000 0%, #30C7B5 100%);
		opacity: 0.5;
	}
	@media (max-width: 767px) {
		.hero-desktop { display: none; }
	}
	@media (max-width: 1024px) and (min-width: 768px) {
		.hero {
			min-height: 65vh;
		}
	}

	/* ===== 2. FEATURE CARDS ===== */
	.features {
		position: relative;
		z-index: 2;
		margin-top: -40px;
		padding-bottom: 40px;
	}
	.features-grid {
		display: flex;
		justify-content: space-evenly;
		gap: 0;
	}
	.feature-card {
		width: 23%;
		background: #ffffff;
		border-radius: 20px;
		border-bottom: 10px solid #000000;
		box-shadow: 0 4px 10px -1px rgba(0,0,0,0.5);
		padding: 20px;
		text-align: center;
		overflow: hidden;
	}
	.feature-icon {
		width: 50%;
		max-width: 50%;
		margin: 20px auto;
		border-radius: 50%;
	}
	.feature-card h2 {
		font-size: 19px;
		color: var(--color-heading);
		margin-bottom: 8px;
	}
	.feature-card p {
		font-size: 15px;
		color: var(--color-text);
		line-height: 1.5;
	}
	@media (max-width: 767px) {
		.features { margin-top: 24px; }
		.features-grid {
			flex-direction: column;
			align-items: center;
			gap: 24px;
		}
		.feature-card {
			width: 100%;
			max-width: 320px;
			margin-bottom: 0;
		}
	}
	@media (max-width: 1024px) and (min-width: 768px) {
		.features-grid { flex-wrap: wrap; justify-content: center; gap: 20px; }
		.feature-card { width: 45%; }
	}

	/* ===== 3. GALLERY — large left, two stacked right ===== */
	.gallery-row {
		padding: 20px 0;
	}
	.gallery-asymmetric {
		display: grid;
		grid-template-columns: 55% 30%;
		grid-template-rows: 1fr 1fr;
		gap: 16px;
		height: auto;
		justify-content: space-between;
	}
	.gallery-big {
		grid-row: 1 / 3;
		border-radius: 10px;
		overflow: hidden;
		box-shadow: 4px 0 10px 0 rgba(0,0,0,0.5);
	}
	.gallery-big img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.gallery-right-img {
		border-radius: 10px;
		overflow: hidden;
		box-shadow: 4px 0 10px 0 rgba(0,0,0,0.5);
	}
	.gallery-right-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	/* ===== 4. GALLERY — 3 equal columns ===== */
	.gallery-three {
		display: flex;
		flex-direction: row;
		gap: 20px;
	}
	.gallery-three-col {
		flex: 1;
		display: flex;
		flex-direction: column;
	}
	.gallery-three-col img {
		width: 100%;
		flex: 1;
		object-fit: cover;
		border-radius: 10px;
		box-shadow: 4px 0 10px 0 rgba(0,0,0,0.5);
	}

	@media (max-width: 767px) {
		.gallery-asymmetric {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			height: auto;
		}
		.gallery-big { grid-row: auto; }
		.gallery-three { flex-direction: column; gap: 16px; }
	}

	/* ===== 5. BEST TRAVEL CTA ===== */
	.best-travel {
		position: relative;
		padding: 100px;
		background: url("https://cdn.sanity.io/images/2voldnur/production/ef24a834fa2adaa6b249191ee5f6378e49418045-1378x775.jpg?w=1378&fm=webp&q=45") center / cover no-repeat;
	}
	@media (max-width: 767px) {
		.best-travel {
			background-image: url("https://cdn.sanity.io/images/2voldnur/production/ef24a834fa2adaa6b249191ee5f6378e49418045-1378x775.jpg?w=640&fm=webp&q=35");
		}
	}
	.best-travel-overlay {
		position: absolute;
		inset: 0;
		background: #000000;
		opacity: 0.63;
	}
	.best-travel-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-wrap: wrap;
		gap: 0;
	}
	.best-travel-text {
		width: 100%;
		text-align: center;
		margin-bottom: 48px;
	}
	.best-travel-label {
		color: #ffffff;
		font-size: 16px;
		margin-bottom: 8px;
	}
	.best-travel-heading {
		color: var(--color-primary-hover);
		font-size: 70px;
		letter-spacing: 2px;
		line-height: 1;
	}
	.best-travel-badges {
		width: 100%;
		display: flex;
		justify-content: center;
		gap: 40px;
	}
	.badge-item {
		display: flex;
		align-items: center;
		gap: 15px;
	}
	.badge-item img {
		width: 80px;
		height: 80px;
		flex-shrink: 0;
	}
	.badge-item strong {
		display: block;
		color: #ffffff;
		font-family: var(--font-heading);
		font-size: 17px;
		margin-bottom: 4px;
	}
	.badge-item p {
		color: #ffffff;
		font-size: 14px;
		margin: 0;
	}
	@media (max-width: 767px) {
		.best-travel { padding: 40px 20px; }
		.best-travel-heading { font-size: 36px; letter-spacing: 1.8px; }
		.best-travel-label { font-size: 14px; }
		.best-travel-text { margin-bottom: 32px; }
		.best-travel-badges { flex-direction: column; gap: 24px; align-items: center; }
		.badge-item strong { font-size: 15px; }
	}

	/* ===== 6. ASSOCIATIONS ===== */
	.associations {
		padding: 80px 0;
		text-align: center;
	}
	.associations h2 {
		font-size: 56px;
		color: var(--color-primary-dark);
		text-transform: uppercase;
		margin-bottom: 40px;
	}
	.assoc-slider {
		display: flex;
		align-items: center;
		gap: 20px;
		max-width: 900px;
		margin: 0 auto;
	}
	.assoc-arrow {
		flex-shrink: 0;
		background: none;
		border: none;
		cursor: pointer;
		color: #ccc;
		padding: 8px;
		transition: color 0.2s;
	}
	.assoc-arrow:hover { color: #999; }
	.assoc-viewport {
		flex: 1;
		overflow: hidden;
