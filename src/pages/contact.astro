---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Contact | 10 Billion Travelers"
  description="Get in touch with 10 Billion Travelers for travel consulting and trip planning."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contact</h1>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Form -->
        <div class="contact-form-wrap">
          <h2>Send Us a Message</h2>
          <form class="contact-form" action="/thank-you/" method="GET">
            <div class="form-group">
              <label for="name">Name <span class="required">*</span></label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number <span class="required">*</span></label>
              <input type="tel" id="phone" name="phone" required />
            </div>
            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input type="email" id="email" name="email" required />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="5"></textarea>
            </div>
            <button type="submit" class="btn">Submit</button>
          </form>
        </div>

        <!-- Info -->
        <div class="contact-info">
          <div class="info-block">
            <h3>Get in Touch</h3>
            <p>We'd love to hear from you. Reach out and let's plan your next adventure together.</p>
          </div>

          <div class="info-block">
            <h3>Business Hours</h3>
            <p>Monday–Friday: 9am–5pm</p>
            <p>Saturday: 10am–3pm</p>
            <p>Sunday: Closed</p>
          </div>

          <div class="info-block">
            <h3>Location</h3>
            <p>Raleigh, NC</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 60px 0 40px;
    text-align: center;
  }
  .page-header h1 {
    text-transform: uppercase;
  }

  .contact-section {
    padding: 0 0 80px;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 64px;
    align-items: start;
  }

  /* Form */
  .contact-form-wrap h2 {
    margin-bottom: 24px;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 6px;
  }
  .required {
    color: var(--color-primary);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-text);
    background: var(--color-white);
    transition: border-color 0.2s ease;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  /* Info */
  .contact-info {
    background: var(--color-white);
    border-radius: 8px;
    padding: 32px;
    border: 1px solid var(--color-border);
  }
  .info-block {
    margin-bottom: 28px;
  }
  .info-block:last-child {
    margin-bottom: 0;
  }
  .info-block h3 {
    margin-bottom: 8px;
    color: var(--color-heading);
  }
  .info-block p {
    font-size: 15px;
    color: var(--color-text-secondary);
    margin-bottom: 4px;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
