---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const services = [
  {
    title: 'Travel Planning',
    description: 'We craft personalized itineraries tailored to your travel style, budget, and dream destinations. From flights and hotels to local experiences, we handle every detail so you can focus on enjoying the journey.',
    image: 'https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?w=800&q=80',
    imageAlt: 'Beautiful forest destination',
  },
  {
    title: 'Hospitality Consulting',
    description: 'With over 1 million miles of travel experience, we know what makes hotels, restaurants, and attractions great. Let us consult with you to elevate your guest experience and increase profitability.',
    image: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=800&q=80',
    imageAlt: 'Mountain landscape',
  },
  {
    title: 'Group & Corporate Travel',
    description: 'Whether it\'s a team retreat, corporate event, or group adventure, we coordinate every element. Our expertise ensures smooth logistics and unforgettable experiences for groups of any size.',
    image: 'https://images.unsplash.com/photo-1454496522488-7a8e488e8606?w=800&q=80',
    imageAlt: 'Mountain hiking group',
  },
];

const faqs = [
  {
    question: 'How do I book a consultation?',
    answer: 'Simply visit our Contact page or click the Email Us button on any page. We\'ll get back to you within 24 hours to schedule a call.',
  },
  {
    question: 'What destinations do you specialize in?',
    answer: 'Kevin has traveled to 26 countries and counting. We specialize in both popular destinations and off-the-beaten-path adventures worldwide.',
  },
  {
    question: 'Do you offer group travel packages?',
    answer: 'Yes! We coordinate group travel for corporate retreats, family vacations, and adventure groups of any size.',
  },
];
---

<Layout
  title="Services | 10 Billion Travelers"
  description="Travel planning, hospitality consulting, and group travel services from 10 Billion Travelers."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Services</h1>
    </div>
  </section>

  <!-- Services -->
  <section class="services-section">
    <div class="container">
      {services.map((service, i) => (
        <div class:list={['service-row', { reverse: i % 2 === 1 }]}>
          <div class="service-image">
            <img src={service.image} alt={service.imageAlt} loading="lazy" />
          </div>
          <div class="service-content">
            <h2>{service.title}</h2>
            <p>{service.description}</p>
            <a href="/contact/" class="btn">Contact</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2 class="faq-heading">F.A.Q.</h2>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 60px 0 40px;
    text-align: center;
  }
  .page-header h1 {
    text-transform: uppercase;
  }

  .services-section {
    padding: 0 0 80px;
  }
  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-bottom: 64px;
  }
  .service-row.reverse {
    direction: rtl;
  }
  .service-row.reverse > * {
    direction: ltr;
  }
  .service-image img {
    width: 100%;
    height: 360px;
    object-fit: cover;
    border-radius: 8px;
  }
  .service-content h2 {
    margin-bottom: 16px;
  }
  .service-content p {
    margin-bottom: 24px;
    line-height: 1.7;
  }

  .faq-section {
    padding: 60px 0 80px;
    background: var(--color-white);
  }
  .faq-heading {
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  .faq-list {
    max-width: 700px;
    margin: 0 auto;
  }
  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding: 20px 0;
  }
  .faq-item summary {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 18px;
    color: var(--color-heading);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item summary::after {
    content: '+';
    font-size: 24px;
    color: var(--color-primary);
    transition: transform 0.2s ease;
  }
  .faq-item[open] summary::after {
    content: '−';
  }
  .faq-item p {
    margin-top: 12px;
    line-height: 1.7;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .service-row {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .service-row.reverse {
      direction: ltr;
    }
    .service-image img {
      height: 240px;
    }
  }
</style>
