---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

const services = [
	{
		title: "Travel Planning",
		description:
			"Let us help you plan your next adventure. From destination research to booking flights and accommodations, we handle every detail so you can focus on the experience.",
	},
	{
		title: "Hospitality Consulting",
		description:
			"With over 1 million miles of travel experience, Kevin White offers expert consulting for hospitality businesses looking to improve their guest experience.",
	},
	{
		title: "Group Travel",
		description:
			"We coordinate group travel for corporate retreats, family vacations, and adventure groups of any size. Let us take the stress out of group logistics.",
	},
];

const faqs = [
	{
		question: "How do I book a consultation?",
		answer:
			"Visit our Contact page or click the Email Us button on any page. We'll get back to you within 24 hours to schedule a call.",
	},
	{
		question: "What destinations do you specialize in?",
		answer:
			"Kevin has traveled to 26 countries and counting. We specialize in both popular destinations and off-the-beaten-path adventures worldwide.",
	},
	{
		question: "Do you offer group travel packages?",
		answer:
			"Yes! We coordinate group travel for corporate retreats, family vacations, and adventure groups of any size.",
	},
];
---

<Layout
  title="Services | 10 Billion Travelers"
  description="Travel planning, hospitality consulting, and group travel services from 10 Billion Travelers in Raleigh, NC."
>
  <section class="page-header">
    <div class="container">
      <h1>Services</h1>
    </div>
  </section>

  <section class="services-section">
    <div class="container">
      {services.map((service, i) => (
        <div class:list={['service-row', { reverse: i % 2 === 1 }]}>
          <div class="service-image">
            <div class="image-placeholder">Service image — will be loaded from Sanity</div>
          </div>
          <div class="service-content">
            <h2>{service.title}</h2>
            <p>{service.description}</p>
            <a href="/contact/" class="btn">Contact</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <h2>F.A.Q.</h2>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: var(--color-white);
    padding: 60px 0;
    text-align: center;
    border-bottom: 1px solid var(--color-border);
  }
  .page-header h1 {
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .services-section {
    padding: 60px 0;
  }
  .service-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    margin-bottom: 60px;
  }
  .service-row.reverse {
    direction: rtl;
  }
  .service-row.reverse > * {
    direction: ltr;
  }
  .image-placeholder {
    background: var(--color-bg-light);
    padding: 80px 20px;
    text-align: center;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .service-content h2 {
    margin-bottom: 16px;
  }
  .service-content p {
    margin-bottom: 24px;
  }

  .faq-section {
    padding: 60px 0;
    background: var(--color-white);
  }
  .faq-section h2 {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 40px;
  }
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }
  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding: 20px 0;
  }
  .faq-item summary {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 17px;
    color: var(--color-heading);
    cursor: pointer;
    list-style: none;
  }
  .faq-item summary::before {
    content: '+ ';
    color: var(--color-primary);
    font-weight: 700;
  }
  .faq-item[open] summary::before {
    content: '− ';
  }
  .faq-item p {
    margin-top: 12px;
    padding-left: 20px;
  }

  @media (max-width: 768px) {
    .service-row {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .service-row.reverse { direction: ltr; }
  }
</style>
