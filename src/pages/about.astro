---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient, urlFor } from '../lib/sanity';

const member = await sanityClient.fetch(
  `*[_type == "teamMember"][0] { name, role, photo, photoCaption, tagline, bio }`
);
---

<Layout
  title="Experienced Travel Consultants | 10 Billion Travelers"
  description="Discover how our travel consultants at 10 Billion Travelers can tailor your dream vacations."
>
  <div class="breadcrumb">
    <div class="container">
      <a href="/">Home</a> <span>/</span> <span>About</span>
    </div>
  </div>

  <section class="story-section">
    <div class="container" style="text-align: center;">
      <h1>Our Story</h1>
      {member?.tagline && <p class="story-tagline">{member.tagline}</p>}
    </div>
  </section>

  <section class="bio-section">
    <div class="container">
      <div class="bio-grid fade-up">
        <div class="bio-photo">
          {member?.photo && (
            <img
              src={urlFor(member.photo).width(400).auto('format').url()}
              alt={member.name}
              loading="lazy"
            />
          )}
          {member?.photoCaption && <p class="photo-caption">{member.photoCaption}</p>}
        </div>
        <div class="bio-text">
          <h2>{member?.name || 'Kevin White'}</h2>
          {member?.bio?.map((block: any) => (
            <p>{block.children?.map((child: any) => child.text).join('')}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="about-cta fade-up">
    <div class="container about-cta-inner">
      <h2>Have a Question?</h2>
      <h3>We'd Love to Hear From You</h3>
      <a href="/contact/" class="btn about-cta-btn">Email Us</a>
    </div>
  </section>
</Layout>

<style>
  .breadcrumb { padding: 16px 0; font-size: 14px; color: var(--color-text-secondary); }
  .breadcrumb a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb span { margin: 0 6px; }
  .story-section { padding: 80px 0 40px; }
  .story-section h1 { text-transform: uppercase; margin-bottom: 24px; }
  .story-tagline { font-size: 20px; max-width: 700px; margin: 0 auto; line-height: 1.6; font-style: italic; }
  .bio-section { padding: 40px 0 80px; }
  .bio-grid { display: grid; grid-template-columns: 300px 1fr; gap: 48px; align-items: start; }
  .bio-photo img { width: 100%; border-radius: 71px; aspect-ratio: 283/300; object-fit: cover; }
  .photo-caption { text-align: center; font-size: 14px; color: var(--color-text-secondary); margin-top: 12px; font-style: italic; }
  .bio-text h2 { text-transform: uppercase; margin-bottom: 20px; }
  .bio-text p { margin-bottom: 16px; line-height: 1.7; }
  .about-cta { padding: 60px 0 80px; background: var(--color-white); }
  .about-cta-inner { text-align: center; }
  .about-cta h2 { text-transform: uppercase; margin-bottom: 8px; }
  .about-cta h3 { color: var(--color-text-secondary); font-weight: 500; }
  .about-cta-btn { margin-top: 24px; }
  @media (max-width: 768px) {
    .bio-grid { grid-template-columns: 1fr; text-align: center; }
    .bio-photo { max-width: 250px; margin: 0 auto; }
    .bio-text { text-align: left; }
    .story-tagline { font-size: 18px; }
  }
</style>
