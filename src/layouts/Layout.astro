---
interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}
const {
	title,
	description = "10 Billion Travelers — expertly crafted tours and personalized travel experiences",
	ogImage = "",
} = Astro.props;
const canonical = new URL(
	Astro.url.pathname,
	Astro.site || "https://10btravelers.com",
).href;
const currentPath = Astro.url.pathname;

const navLinks = [
	{ href: "/", label: "Home" },
	{ href: "/about/", label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "10 Billion Travelers",
      "url": "https://10btravelers.com",
      "description": "Travel consulting by Kevin White — 1 million miles, 26 countries"
    })} />
    <slot name="head" />
  </head>
  <body>
    <header class="header">
      <div class="header-inner container">
        <a href="/" class="logo" aria-label="10 Billion Travelers Home">
          <img src="https://10btravelers.com/wp-content/uploads/2023/11/ezgif.com-optiwebp-7.webp" alt="10 Billion Travelers" width="150" height="150" class="logo-img" />
          <span class="logo-text">NEW 10 BILLION TRAVELERS</span>
        </a>
        <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
        <nav class="main-nav" aria-label="Main navigation">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href }]}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner container">
        <div class="footer-col">
          <p class="footer-brand">NEW 10 BILLION TRAVELERS</p>
          <p class="footer-tagline">Inspiring travelers around the world</p>
        </div>
        <div class="footer-col">
          <p class="footer-heading">Quick Links</p>
          <nav aria-label="Footer navigation">
            {navLinks.map(link => (
              <a href={link.href} class="footer-link">{link.label}</a>
            ))}
          </nav>
        </div>
        <div class="footer-col">
          <p class="footer-heading">Connect</p>
          <p>Raleigh, NC</p>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container">
          <p>&copy; {new Date().getFullYear()} 10 Billion Travelers. All rights reserved.</p>
          <p class="footer-powered">Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener noreferrer">Spirit Media</a></p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.mobile-toggle');
      const nav = document.querySelector('.main-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          nav.classList.toggle('open');
        });
      }
    </script>
  </body>
</html>

<style>
  .header {
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    padding-bottom: 12px;
  }
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-img {
    width: 55px;
    height: 55px;
  }
  .logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-primary);
    line-height: 1.2;
  }
  .main-nav {
    display: flex;
    gap: 32px;
    align-items: center;
    align-self: center;
  }
  .nav-link {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    color: #000000;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 4px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 2px;
    background: var(--color-primary);
    transition: width 0.3s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: var(--color-primary-hover);
    border: none;
    padding: 10px;
    border-radius: 4px;
    cursor: pointer;
  }
  .mobile-toggle .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-white);
  }
  @media (max-width: 768px) {
    .mobile-toggle { display: flex; }
    .main-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-white);
      flex-direction: column;
      padding: 24px;
      gap: 16px;
      border-bottom: 1px solid var(--color-border);
    }
    .main-nav.open { display: flex; }
  }

  .footer {
    background: var(--color-white);
    border-top: 1px solid var(--color-border);
    margin-top: 0;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    padding-top: 40px;
    padding-bottom: 40px;
  }
  .footer-brand {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-heading);
  }
  .footer-tagline {
    font-size: 15px;
    color: var(--color-text-secondary);
    margin-top: 8px;
  }
  .footer-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 19px;
    color: var(--color-heading);
    margin-bottom: 16px;
  }
  .footer-col nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-link {
    color: var(--color-primary);
    font-size: 15px;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-link:hover { color: var(--color-primary-hover); }
  .footer-col p {
    font-size: 15px;
    color: var(--color-text-secondary);
    margin: 0 0 8px;
  }
  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 20px 0;
    text-align: center;
  }
  .footer-bottom p {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .footer-powered {
    margin-top: 4px;
    font-size: 13px;
    color: var(--color-text-secondary);
    opacity: 0.7;
  }
  .footer-powered a {
    color: var(--color-primary);
    font-weight: 600;
  }
  .footer-powered a:hover {
    color: var(--color-primary-hover);
  }
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-top: 32px;
      padding-bottom: 32px;
    }
  }
</style>
