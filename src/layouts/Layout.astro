---
interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}
const {
	title,
	description = "10 Billion Travelers — expertly crafted tours and personalized travel experiences",
	ogImage = "",
} = Astro.props;
const canonical = new URL(
	Astro.url.pathname,
	Astro.site || "https://10btravelers.com",
).href;
const currentPath = Astro.url.pathname;

const navLinks = [
	{ href: "/", label: "Home" },
	{ href: "/about/", label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/montserrat/montserrat-700.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/lato/lato-400.woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "10 Billion Travelers",
      "url": "https://10btravelers.com",
      "description": "Travel consulting by Kevin White — 1 million miles, 26 countries"
    })} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <header class="header">
      <div class="header-inner container">
        <a href="/" class="logo" aria-label="10 Billion Travelers Home">
          <img src="https://cdn.sanity.io/images/2voldnur/production/c72fa126e31f5111a46f5684fb45d30ed84c12e9-150x150.webp?w=110&h=110&fm=webp&q=80" alt="10 Billion Travelers" width="55" height="55" class="logo-img" fetchpriority="high" decoding="async" />
          <span class="logo-text">10 BILLION TRAVELERS</span>
        </a>
        <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
        <nav class="main-nav" aria-label="Main navigation">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath === link.href }]}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner container">
        <div class="footer-col">
          <h2 class="footer-heading">About Us</h2>
          <div class="footer-about">
            <img src="https://cdn.sanity.io/images/2voldnur/production/89a8d90403c115a7e92ce20c881df2696054c461-140x140.jpg?w=130&h=130&fm=webp&q=80" alt="Kevin White" width="65" height="65" class="footer-avatar" loading="lazy" decoding="async" />
            <p>I was born to travel! I've logged over 1 million miles to 26 different countries. Before I'm 100 years old there will be 10 Billion people alive. Our team is inspiring &amp; facilitating as many travelers as possible.</p>
          </div>
        </div>
        <div class="footer-col">
          <h2 class="footer-heading">Connect</h2>
          <div class="footer-social">
            <a href="https://www.facebook.com/10BTravelers/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Facebook">
              <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M504 256C504 119 393 8 256 8S8 119 8 256c0 123.78 90.69 226.38 209.25 245V327.69h-63V256h63v-54.64c0-62.15 37-96.48 93.67-96.48 27.14 0 55.52 4.84 55.52 4.84v61h-31.28c-30.8 0-40.41 19.12-40.41 38.73V256h68.78l-11 71.69h-57.78V501C413.31 482.38 504 379.78 504 256z"></path></svg>
            </a>
            <a href="https://twitter.com/1Travelers" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Twitter">
              <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M459.37 151.716c.325 4.548.325 9.097.325 13.645 0 138.72-105.583 298.558-298.558 298.558-59.452 0-114.68-17.219-161.137-47.106 8.447.974 16.568 1.299 25.34 1.299 49.055 0 94.213-16.568 130.274-44.832-46.132-.975-84.792-31.188-98.112-72.772 6.498.974 12.995 1.624 19.818 1.624 9.421 0 18.843-1.3 27.614-3.573-48.081-9.747-84.143-51.98-84.143-102.985v-1.299c13.969 7.797 30.214 12.67 47.431 13.319-28.264-18.843-46.781-51.005-46.781-87.391 0-19.492 5.197-37.36 14.294-52.954 51.655 63.675 129.3 105.258 216.365 109.807-1.624-7.797-2.599-15.918-2.599-24.04 0-57.828 46.782-104.934 104.934-104.934 30.213 0 57.502 12.67 76.67 33.137 23.715-4.548 46.456-13.32 66.599-25.34-7.798 24.366-24.366 44.833-46.132 57.827 21.117-2.273 41.584-8.122 60.426-16.243-14.292 20.791-32.161 39.308-52.628 54.253z"></path></svg>
            </a>
            <a href="https://www.youtube.com/channel/UCs99zYse2OsPNYlPBWQTzog" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="YouTube">
              <svg viewBox="0 0 576 512" xmlns="http://www.w3.org/2000/svg"><path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"></path></svg>
            </a>
            <a href="https://www.instagram.com/10btravelers/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
              <svg viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path></svg>
            </a>
          </div>
        </div>
        <div class="footer-col footer-col-gallery">
          <h2 class="footer-heading">Gallery</h2>
          <div class="footer-gallery-grid">
            <img src="https://cdn.sanity.io/images/2voldnur/production/c690863d1d5fc840e8c4ffe32ef84278bf503244-150x150.webp?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/fb825482b2025d7885706e67a799a23c36efc35d-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/59163ae11d7908ebf04dfb9e4ccd56af788591e2-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/1a3b1fdff636a583bdf81c311d4ac0e0134c6ba1-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/efcbf0ea30f8b41c33587bbe20501e50e4dff55e-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/f8bf82df36476f20fc05447092d737581c240c40-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/40105400cedb9c275a180de96803106ffa711eb7-1204x1204.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/e9ac44b428e63894467d4cfa921839aeab0285a0-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
            <img src="https://cdn.sanity.io/images/2voldnur/production/ae5fc9d367885d32354bbac83bca3b0d1df378e0-1200x1200.jpg?w=200&h=200&fm=webp&q=70" alt="Travel photo" width="100" height="100" loading="lazy" decoding="async" />
          </div>
        </div>
        <div class="footer-col footer-col-contact">
          <h2 class="footer-heading">Get in Touch</h2>
          <p class="footer-address">205 S Academy St #3251<br />Cary, NC 27519</p>
          <a href="mailto:kevin@10btravelers.com" class="footer-email-btn">Email Us</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container footer-bottom-inner">
          <p>&copy; {new Date().getFullYear()} 10 Billion Travelers. All rights reserved. &bull; Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener noreferrer">Spirit Media</a></p>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.querySelector('.mobile-toggle');
      const nav = document.querySelector('.main-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          nav.classList.toggle('open');
        });
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100px;
    left: 0;
    background: var(--color-primary);
    color: #fff;
    padding: 12px 24px;
    z-index: 200;
    font-weight: 600;
  }
  .skip-link:focus {
    top: 0;
  }
  .header {
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    padding-bottom: 12px;
  }
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-img {
    width: 55px;
    height: 55px;
  }
  .logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 20px;
    color: var(--color-primary);
    line-height: 1.2;
  }
  .main-nav {
    display: flex;
    gap: 32px;
    align-items: center;
    align-self: center;
  }
  .nav-link {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    color: #000000;
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 4px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 2px;
    background: var(--color-primary);
    transition: width 0.3s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: var(--color-primary-hover);
    border: none;
    padding: 12px;
    border-radius: 4px;
    cursor: pointer;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }
  .mobile-toggle .bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-white);
  }
  @media (max-width: 768px) {
    .mobile-toggle { display: flex; }
    .main-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-white);
      flex-direction: column;
      padding: 24px;
      gap: 16px;
      border-bottom: 1px solid var(--color-border);
    }
    .main-nav.open { display: flex; }
  }

  .footer {
    background: var(--color-bg);
    margin-top: 0;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1fr;
    gap: 2.5rem;
    max-width: 1240px;
    margin: 0 auto;
    padding: 4rem 3rem;
    align-items: start;
  }
  .footer-heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 20px;
    color: var(--color-primary-hover);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .footer-about {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .footer-avatar {
    width: 65px;
    height: 65px;
    flex-shrink: 0;
    border-radius: 50%;
    object-fit: cover;
  }
  .footer-about p {
    font-size: 14px;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }
  .footer-social {
    display: flex;
    gap: 8px;
    justify-content: left;
  }
  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: rgba(255,255,255,0.14);
    border-radius: 10%;
    transition: opacity 0.2s;
  }
  .social-icon:hover { opacity: 0.8; }
  .social-icon svg {
    width: 20px;
    height: 20px;
    fill: var(--color-text);
  }
  .footer-gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
  }
  .footer-gallery-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    opacity: 0.8;
    cursor: pointer;
    border-radius: 2px;
  }
  .footer-gallery-grid img:hover {
    opacity: 1;
  }
  .footer-address {
    font-size: 14px;
    color: var(--color-text);
    line-height: 1.6;
    margin: 0 0 12px;
  }
  .footer-email-btn {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 8px 20px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .footer-email-btn:hover {
    background: var(--color-primary-hover);
  }
  .footer-col p {
    font-size: 14px;
    color: var(--color-text);
    margin: 0 0 6px;
  }
  .footer-bottom {
    background: #1a8a7d;
    padding: 16px 0;
  }
  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 3rem;
  }
  .footer-bottom p {
    font-size: 16px;
    color: #ffffff;
    margin: 0;
  }
  .footer-bottom a {
    color: #ffffff;
    font-weight: 600;
  }
  .footer-bottom a:hover {
    color: #ffffff;
    opacity: 0.8;
  }
  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding: 3rem 2rem;
    }
  }
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 1.5rem;
    }
    .footer-about { flex-direction: row; align-items: flex-start; text-align: left; }
    .footer-bottom-inner { flex-direction: column; gap: 8px; text-align: center; }
    .footer-bottom p { font-size: 16px; }
  }
</style>
